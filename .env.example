# Prisma 5 — SQLite (chemin relatif à la racine du projet en prod, préférez un chemin absolu)
DATABASE_URL="file:./dev.db"

# Token attendu dans ?token= pour GET /report
IOT_SERVER_TOKEN="change-me"

# Nombre de lectures affichées dans les graphiques (défaut : 72)
CHART_READINGS_LIMIT=72

# PM2 (ecosystem.config.cjs) — port d'écoute du serveur Node
# PORT=3000
# HOST=0.0.0.0

# Logs /report (JSON structuré, défaut : logs/report.log)
# LOG_DIR=logs
# REPORT_LOG_PATH=logs/report.log
# LOG_LEVEL=info

# Optionnel : URL publique si les meta og:image sont incorrectes derrière un proxy
# (sinon l'origine de la requête est utilisée automatiquement)
# ORIGIN=https://spider-meter.example.com
