# Prisma 5 — SQLite (chemin relatif à la racine du projet en prod, préférez un chemin absolu)
DATABASE_URL="file:./dev.db"

# Token Shelly (repli si aucun token généré depuis /admin)
IOT_SERVER_TOKEN="change-me"

# Session admin (obligatoire en production — le serveur refuse de démarrer si absent ou faible)
SESSION_SECRET="change-me-long-random-string"

# Bootstrap du premier compte admin (optionnel, une seule fois si BDD vide)
# ADMIN_USERNAME="admin"
# ADMIN_PASSWORD="mot-de-passe-securise"

# Nombre de lectures (legacy / fallback interne)
CHART_READINGS_LIMIT=72

# PM2 (ecosystem.config.cjs)
# PORT=1212
# HOST=0.0.0.0

# Logs /report
# LOG_DIR=logs
# REPORT_LOG_PATH=logs/report.log
# LOG_LEVEL=info

# Meta Open Graph derrière proxy
# ORIGIN=https://spider-meter.example.com
