{
	"name": "spider-meter",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "prisma generate && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && prisma generate || echo ''",
		"postinstall": "svelte-kit sync && prisma generate",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"db:seed": "npx tsx prisma/seed.ts",
		"db:generate": "prisma generate",
		"start": "node --import dotenv/config build/index.js",
		"pm2:start": "pm2 start ecosystem.config.cjs",
		"pm2:stop": "pm2 stop spider-meter",
		"pm2:restart": "pm2 restart spider-meter",
		"pm2:logs": "pm2 logs spider-meter"
	},
	"prisma": {
		"seed": "npx tsx prisma/seed.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^25.8.0",
		"chartjs-adapter-date-fns": "^3.0.0",
		"pino-pretty": "^13.1.3",
		"prisma": "^5.22.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tsx": "^4.19.4",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@prisma/client": "^5.22.0",
		"@tailwindcss/vite": "^4.3.0",
		"bcryptjs": "^3.0.2",
		"chart.js": "^4.5.1",
		"date-fns": "^4.1.0",
		"dotenv": "^16.5.0",
		"image-size": "^2.0.2",
		"minio": "^8.0.7",
		"phosphor-svelte": "^3.1.0",
		"pino": "^10.3.1",
		"tailwindcss": "^4.3.0"
	}
}
