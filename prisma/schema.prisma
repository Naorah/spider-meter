generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SensorReading {
  id          Int      @id @default(autoincrement())
  deviceId    String   @map("device_id")
  humidity    Float
  temperature Float
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("sensor_readings")
}
