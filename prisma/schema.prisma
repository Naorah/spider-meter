generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SensorReading {
  id          Int      @id @default(autoincrement())
  deviceId    String   @map("device_id")
  humidity    Float
  temperature Float
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("sensor_readings")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

model SpiderProfile {
  id               Int      @id @default(1)
  name             String
  commonName       String   @map("common_name")
  scientificName   String   @map("scientific_name")
  speciesNotes     String   @map("species_notes")
  movedInDate      DateTime @map("moved_in_date")

  @@map("spider_profiles")
}

model Molt {
  id        Int      @id @default(autoincrement())
  name      String
  moltDate  DateTime @map("molt_date")
  sortOrder Int      @default(0) @map("sort_order")

  @@map("molts")
}

model NewsItem {
  id          Int      @id @default(autoincrement())
  title       String
  body        String
  publishedAt DateTime @default(now()) @map("published_at")

  @@index([publishedAt(sort: Desc)])
  @@map("news_items")
}

model AppSetting {
  key   String @id
  value String

  @@map("app_settings")
}

model GalleryPhoto {
  id          Int      @id @default(autoincrement())
  objectKey  String   @unique @map("object_key")
  caption     String
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  width       Int?
  height      Int?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("gallery_photos")
}
